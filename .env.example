# ==========================================
# Construction IQ - Environment Template
# ==========================================

# 1. Application Settings
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*
API_PREFIX=/api/v1

# 2. Database Connections
# PostgreSQL Connection String
DATABASE_URL=postgresql://ciq:ciq_secret@localhost:5432/construction_iq

# Redis Connection String (Optional, for BullMQ)
REDIS_URL=redis://localhost:6379

# 3. Authentication
# REQUIRED: Change this in production!
JWT_SECRET=super-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# 4. AI Configuration
AI_DEFAULT_PROVIDER=openai
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000
AI_TIMEOUT_MS=30000
AI_RETRY_COUNT=3

# Specific Model Overrides
AI_MODEL_OPENAI=gpt-4o
AI_MODEL_ANTHROPIC=claude-3-5-sonnet-20240620
AI_MODEL_GEMINI=gemini-1.5-pro

# 5. Frontend Connectors (if applicable)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
